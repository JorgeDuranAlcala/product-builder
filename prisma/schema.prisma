generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  PRODUCT_MANAGER
  VIEWER
  AUDITOR
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         UserRole @default(PRODUCT_MANAGER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// ─── Product core enums ─────────────────────────────────────────────────────

enum ProductBranch {
  AUTOMOVIL
  SALUD
  VIDA
  PATRIMONIAL
  INCLUSIVO
  RCV_OBLIGATORIO
}

enum ContractCurrency {
  VES
  USD
  INDEXADO
}

enum EmissionType {
  EMISION_GARANTIZADA
  REQUIERE_DECLARACION_SALUD
  REQUIERE_INSPECCION
}

enum ProductStatus {
  DRAFT
  ACTUARIAL_REVIEW
  SUBMITTED_TO_SUDEASEG
  APPROVED_ACTIVE
  REJECTED
}

enum RenewalFrequency {
  ANUAL
  SEMESTRAL
  TRIMESTRAL
  MENSUAL
}

enum RenewalType {
  NORMAL
  TACITA
  CON_AVISO
}

enum DeductibleType {
  MONTO_FIJO
  PORCENTAJE_SINIESTRO
  PORCENTAJE_SUMA_ASEGURADA
}

enum DocumentType {
  CONDICIONES_GENERALES
  CONDICIONES_PARTICULARES
  NOTA_TECNICA_ACTUARIAL
  POLIZA
  CUADRO_RECIBO
}

enum FormFieldType {
  TEXT
  NUMBER
  SELECT
  DATE
  BOOLEAN
}

enum FlowStepKey {
  CLIENT_DATA
  RISK_DATA
  PLANS_COVERAGES
  DOCUMENTS_OCR
  DIGITAL_SIGNATURE
  AI_INSPECTION
  TECHNICAL_APPROVAL
  PAYMENT
  FINISHED
}

enum RatingVariableType {
  NUMBER
  SELECT
  TEXT
  BOOLEAN
  DATE
}

enum CommercialChannelType {
  TRADICIONAL
  ALTERNATIVO
  DIGITAL
}

// ─── Product ────────────────────────────────────────────────────────────────

model Product {
  id                         String           @id @default(uuid())
  commercialName             String
  internalCode               String           @unique
  branch                     ProductBranch
  currency                   ContractCurrency
  emissionType               EmissionType
  status                     ProductStatus    @default(DRAFT)
  simplifiedContract         Boolean          @default(false)
  uniformConditions          Boolean          @default(false)
  lockedGeneralConditions    Boolean          @default(false)
  numeroProvidenciaSudeaseg  String?
  fechaGacetaAprobacion      DateTime?        @db.Date
  isImmutable                Boolean          @default(false)
  subPlanCode                String?
  vigenciaInicio             DateTime?        @db.Date
  vigenciaFin                DateTime?        @db.Date
  allowsQuickEmission        Boolean          @default(false)
  renewalFrequency           RenewalFrequency @default(ANUAL)
  renewalType                RenewalType      @default(NORMAL)
  premiumGuaranteeDays       Int              @default(30)
  annualClosingMonth         Int              @default(12)
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  coverages          Coverage[]
  actuarialData      ActuarialData?
  exclusions         Exclusion[]
  legalDocuments     LegalDocument[]
  commercialChannels CommercialChannel[]
  requiredDocuments  RequiredDocument[]
  productPlans       ProductPlan[]
  flowStepConfigs    FlowStepConfig[]
  formFields         FormField[]
  stateHistory       StateHistory[]
  sisipConfig        SisipConfig?

  @@map("products")
}

// ─── Coverages ──────────────────────────────────────────────────────────────

model Coverage {
  id                      String          @id @default(uuid())
  productId               String
  name                    String
  description             String?
  sortOrder               Int             @default(0)
  isBasicMandatory        Boolean         @default(false)
  insuredSumMin           Decimal?        @db.Decimal(18, 2)
  insuredSumMax           Decimal?        @db.Decimal(18, 2)
  insuredSumFixed         Decimal?        @db.Decimal(18, 2)
  deductibleType          DeductibleType?
  deductibleValue         Decimal?        @db.Decimal(18, 2)
  waitingPeriodDays       Int             @default(0)
  tariffPremium           Decimal?        @db.Decimal(18, 2)
  vigenciaDesde           DateTime?       @db.Date
  vigenciaHasta           DateTime?       @db.Date
  dependsOnCoverageName   String?
  coberturaInternaCode    String?
  tarifaInternaCode       String?
  treatmentType           String?
  calculationService      String?
  reinsuranceContractCode String?
  reinsuranceContractName String?
  reinsuranceBranchCode   String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("coverages")
}

// ─── Actuarial ──────────────────────────────────────────────────────────────

model ActuarialData {
  id                     String   @id @default(uuid())
  productId              String   @unique
  purePremium            Decimal  @db.Decimal(18, 4)
  administrativeExpenses Decimal  @db.Decimal(8, 4)
  commissions            Decimal  @db.Decimal(8, 4)
  profitMargin           Decimal  @db.Decimal(8, 4)
  commercialPremium      Decimal  @db.Decimal(18, 4)
  actuaryName            String
  actuaryCedula          String
  actuarySudeasegNumber  String
  technicalNoteUrl       String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  ratingVariables  RatingVariable[]

  @@map("actuarial_data")
}

model RatingVariable {
  id              String             @id @default(uuid())
  actuarialDataId String
  name            String
  label           String
  variableType    RatingVariableType
  required        Boolean            @default(true)
  sortOrder       Int                @default(0)
  options         Json?

  actuarialData ActuarialData @relation(fields: [actuarialDataId], references: [id], onDelete: Cascade)

  @@index([actuarialDataId])
  @@map("rating_variables")
}

// ─── Legal ──────────────────────────────────────────────────────────────────

model Exclusion {
  id                  String  @id @default(uuid())
  productId           String
  text                String
  sortOrder           Int     @default(0)
  typographyHighlight Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("exclusions")
}

model LegalDocument {
  id                   String       @id @default(uuid())
  productId            String
  documentType         DocumentType
  title                String
  content              String       @db.Text
  isLocked             Boolean      @default(false)
  isSimplifiedTemplate Boolean      @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("legal_documents")
}

model CommercialChannel {
  id          String                @id @default(uuid())
  productId   String
  name        String
  channelType CommercialChannelType @default(ALTERNATIVO)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("commercial_channels")
}

model RequiredDocument {
  id          String  @id @default(uuid())
  productId   String
  documentKey String
  label       String
  required    Boolean @default(true)
  sortOrder   Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("required_documents")
}

// ─── Commercial plans ───────────────────────────────────────────────────────

model ProductPlan {
  id             String   @id @default(uuid())
  productId      String
  name           String
  description    String?
  badge          String?
  priceFactor    Decimal  @db.Decimal(8, 4) @default(1)
  isRecommended  Boolean  @default(false)
  coverageIds    Json
  coverageLabels Json
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_plans")
}

// ─── Emission flow ──────────────────────────────────────────────────────────

model FlowStepConfig {
  id          String      @id @default(uuid())
  productId   String
  stepKey     FlowStepKey
  label       String
  shortLabel  String?
  description String?
  enabled     Boolean     @default(true)
  formEnabled Boolean     @default(true)
  sortOrder   Int         @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, stepKey])
  @@index([productId])
  @@map("flow_step_configs")
}

model FormField {
  id        String        @id @default(uuid())
  productId String
  label     String
  fieldType FormFieldType
  required  Boolean       @default(true)
  options   Json?
  sortOrder Int           @default(0)
  stepKey   FlowStepKey   @default(RISK_DATA)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("form_fields")
}

// ─── Workflow ───────────────────────────────────────────────────────────────

model StateHistory {
  id         String         @id @default(uuid())
  productId  String
  fromStatus ProductStatus?
  toStatus   ProductStatus
  comment    String?
  changedAt  DateTime       @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("state_history")
}

// ─── SISIP (optional) ───────────────────────────────────────────────────────

model SisipConfig {
  id                    String  @id @default(uuid())
  productId             String  @unique
  ramoInternoCode       String?
  ramoInternoName       String?
  branchAlias1          String?
  branchAlias2          String?
  producerCode          String?
  producerName          String?
  assignToAllProducers  Boolean @default(false)
  counterCotizacion     String?
  counterPoliza         String?
  counterRecibo         String?
  counterSiniestro      String?
  maskPoliza            String?
  maskRecibo            String?
  maskSiniestro         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("sisip_configs")
}
